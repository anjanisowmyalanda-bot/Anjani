#include <stdio.h>
#include <string.h>

struct student {
    int rollNo;
    char name[50];
    float marks;
};

int main() {
    struct student s1;

    s1.rollNo = 101;
    strcpy(s1.name, "Anjani");
    s1.marks = 85.5;

    printf("Student Details:\n");
    printf("Roll No: %d\n", s1.rollNo);
    printf("Name: %s\n", s1.name);
    printf("Marks: %.2f\n", s1.marks);
    printf ("25331A05F9");
    return 0;
}
