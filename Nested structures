#include <stdio.h>
#include <string.h>

struct Address {
    int rollno;
    char city[30];
    int pincode;
};

struct Student {
    int rollno;
    char name[50];
    struct Address addr; 
};

int main() {
    struct Student s1;

    s1.rollno = 101;
    strcpy(s1.name, "Anju");

    strcpy(s1.addr.city, "VZM");
    s1.addr.pincode = 535006;

    printf("Student Details:\n");
    printf("Roll No: %d\n", s1.rollno);
    printf("Name: %s\n", s1.name);
    printf("City: %s\n", s1.addr.city);
    printf("Pincode: %d\n", s1.addr.pincode);
    printf ("25331A05F9");
    return 0;
}
