#include <stdio.h>

void display(int arr[], int size);

int main() {
    int arr[5] = {10, 20, 30, 40, 50};
    int size = sizeof(arr) / sizeof(arr[0]);

    display(arr, size);
    printf("25331A05F9");

    return 0;
}

void display(int arr[], int size) {
    int i;

    printf("Array elements are:\n");

    for (i = 0; i < size; i++) {
        printf("%d\n", arr[i]);
    }
}
