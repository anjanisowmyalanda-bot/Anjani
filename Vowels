#include <stdio.h>

int main() {
    char str[50];
    int i, v = 0;

    printf("Enter a string: ");
    scanf("%s", str);

    for (i = 0; str[i] != '\0'; i++) {
        if (str[i] == 'a' || str[i] == 'e' ||
            str[i] == 'i' || str[i] == 'o' ||
            str[i] == 'u') {
            v++;
        }
    }

    printf("No. of vowels = %d\n", v);
    printf("25331A05F9");
    return 0;
}
