#include <stdio.h>
int fact(int n) {
    if (n == 0 || n == 1)
        return 1;
    else
        return n * fact(n - 1);
}

int main() {
    int n, r, nCr;

    printf("Enter value of n: ");
    scanf("%d", &n);

    printf("Enter value of r: ");
    scanf("%d", &r);

    if (n > r && n >= 0 && r >= 0) {
        nCr = fact(n) / (fact(r) * fact(n - r));
        printf("nCr = %d", nCr);
    } else {
        printf("Invalid input! Ensure n > r and both are positive.");
    }

    return 0;
}
