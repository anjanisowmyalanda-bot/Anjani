#include <stdio.h>

int prime(int n)
{
    int i;

    for (i = 2; i < n; i++)
    {
        if (n % i == 0)
            return 0;
    }
    return 1;
}

int main()
{
    int n;

    printf("Enter number: ");
    scanf("%d", &n);

    if (prime(n))
        printf("Number is prime\n");
    else
        printf("Number is not prime\n");

    return 0;
}
