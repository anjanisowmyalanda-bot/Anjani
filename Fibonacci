#include <stdio.h>

int main() {
    int n, i;
    int a = 0, b = 1, next;

    printf("Enter number of terms: ");
    scanf("%d", &n);

    printf("Fibonacci Series: ");

    for(i = 0; i < n; i++) {
        printf("%d\n", a);
        next = a + b;
        a = b;
        b = next;
    }
    printf("25331A05F9");
    return 0;
}
