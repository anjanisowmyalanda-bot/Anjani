#include <stdio.h>

int main() {
    int a, b, c, max;

    // Input three numbers
    printf("Enter three numbers: ");
    scanf("%d %d %d", &a, &b, &c);

    // Using conditional operator
    max = (a > b) ? 
          ((a > c) ? a : c) : 
          ((b > c) ? b : c);

    // Output result
    printf("Maximum number is: %d\n", max);

    return 0;
}
